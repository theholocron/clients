{
  "name": "@theholocron/clients",
  "version": "0.0.0",
  "private": true,
  "description": "API Clients used within the Galaxy.",
  "homepage": "https://github.com/theholocron/clients#readme",
  "bugs": "https://github.com/theholocron/clients/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theholocron/clients.git"
  },
  "license": "GPL-3.0",
  "author": "Newton Koumantzelis",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "format": "prettier --write .",
    "lint": "pnpm -r --filter './packages/*' lint",
    "release": "semantic-release",
    "test": "pnpm -r --filter './packages/*' test",
    "test:coverage": "pnpm -r --filter './packages/*' test:coverage",
    "typecheck": "pnpm -r --filter './packages/*' typecheck"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@theholocron/commitlint-config": "catalog:",
    "@theholocron/eslint-config": "catalog:",
    "@theholocron/lint-staged-config": "catalog:",
    "@theholocron/prettier-config": "catalog:",
    "@theholocron/tsconfig": "catalog:",
    "alexjs": "^1.0.0",
    "conventional-changelog-conventionalcommits": "^10.2.0",
    "eslint": "catalog:",
    "globals": "catalog:",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "prettier": "^3.9.3",
    "semantic-release": "^25.0.5",
    "turbo": "^2.5.5",
    "typescript": "catalog:"
  },
  "pnpm": {
    "overrides": {
      "@commitlint/config-conventional": "^19.8.1"
    }
  },
  "packageManager": "pnpm@10.34.4",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "releases": "https://github.com/theholocron/clients/releases",
  "wiki": "https://github.com/theholocron/clients/wiki"
}
